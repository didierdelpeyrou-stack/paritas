{
  "name": "paritas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Paritas : la table des Ateliers. Simulation politique narrative sur le paritarisme français, de 1789 à 2026.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dist": "npm run build && node scripts/dist-package.mjs",
    "serve": "npx serve -l 4321 dist",
    "simulate:events": "node scripts/simulate-events.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/three": "^0.184.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.14",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "three": "^0.184.0",
    "tone": "^15.0.0"
  }
}
